{
  "sourceLanguage" : "en",
  "strings" : {
    "%@ cover" : {
      "comment" : "Accessibility label for a book cover image in the catalog publication list row. %@ is the book title.",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Couverture de %@"
          }
        }
      }
    },
    "%@ cover image" : {
      "comment" : "Accessibility label for the large cover image on the catalog book detail screen. %@ is the book title.",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Image de couverture de %@"
          }
        }
      }
    },
    "%@ icon" : {
      "comment" : "Accessibility label for the catalog icon image in the About This Catalog section. %@ is the catalog title.",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Icône de %@"
          }
        }
      }
    },
    "%@ placeholder" : {
      "comment" : "Accessibility label for a placeholder image when no book cover is available. %@ is the book title.",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Espace réservé pour %@"
          }
        }
      }
    },
    "%lld" : {
      "comment" : "A standalone number, used for displaying counts such as total books in a catalog.",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld"
          }
        }
      }
    },
    "%lld pages left in chapter" : {
      "comment" : "Label in the reader HUD showing how many pages remain in the current chapter.",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld pages restantes dans le chapitre"
          }
        }
      }
    },
    "%lld/%lld" : {
      "comment" : "Fraction display showing current chapter out of total chapters (e.g. 3/12) on the book detail screen.",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$lld/%2$lld"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$lld/%2$lld"
          }
        }
      }
    },
    "%lld%%" : {
      "comment" : "Percentage display (e.g. 42%) shown for reading progress in the library list and reader HUD.",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld%%"
          }
        }
      }
    },
    "Aa" : {
      "comment" : "Button label in the reader HUD bottom bar that toggles the font and spacing options panel. Stylized as 'Aa' to represent typography.",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aa"
          }
        }
      }
    },
    "Abc" : {
      "comment" : "Sample text shown in each font preview button in the reader font picker panel.",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Abc"
          }
        }
      }
    },
    "About This Catalog" : {
      "comment" : "Section header in the catalog feed view showing metadata about the OPDS catalog (icon, description, links).",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "À propos de ce catalogue"
          }
        }
      }
    },
    "Add an OPDS catalog to start browsing books." : {
      "comment" : "Instructional message shown on the Catalogs screen when no catalogs have been added.",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ajoutez un catalogue OPDS pour commencer à parcourir des livres."
