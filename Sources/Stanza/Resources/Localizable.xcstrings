    "Are you sure you want to delete \"%@\"? This cannot be undone." : {
      "comment" : "Confirmation message in the delete book alert dialog. %@ is the book title.",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sind Sie sicher, dass Sie „%@“ löschen möchten? Dies kann nicht rückgängig gemacht werden."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¿Estás seguro de que quieres eliminar «%@»? Esta acción no se puede deshacer."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Êtes-vous sûr de vouloir supprimer « %@ » ? Cette operação est irréversible."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sei sicuro di voler eliminare \"%@\"? L'azione è irreversibile."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「%@」を削除してもよろしいですか？この操作は取り消せません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\"을(를) 삭제하시겠습니까? 이 작업은 취소할 수 없습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tem certeza de que deseja excluir \"%@\"? Isso não pode ser desfeito."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Вы уверены, что хотите удалить «%@»? Это действие нельзя отменить."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "您确定要删除“%@”吗？此操作无法撤销。"
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "هل أنت متأكد أنك تريد حذف \"%@\"؟ لا يمكن التراجع عن هذا الإجراء."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apakah Anda yakin ingin menghapus \"%@\"? Ini tidak bisa dibatalkan."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "क्या आप वाकई \"%@\" को हटाना चाहते हैं? इसे वापस नहीं लिया जा सकता।"
          }
