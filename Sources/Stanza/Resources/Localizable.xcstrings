        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ajouter un signet"
          }
        }
      }
    },
    "Add Catalog" : {
      "comment" : "Button label and navigation title for adding a new OPDS catalog. Used in the Catalogs toolbar and empty state, and as the Add Catalog sheet title.",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ajouter un catalogue"
          }
        }
      }
