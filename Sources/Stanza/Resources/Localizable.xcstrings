        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Êtes-vous sûr de vouloir supprimer « %@ » ? Cette opération est irréversible."
          }
        }
      }
    },
    "Athelas" : {
      "comment" : "Font family name displayed in the font picker. This is a proper noun and may not need translation."
    },
    "Author" : {
