        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ajouter un livre"
          }
        }
      }
    },
    "Add bookmark" : {
      "comment" : "Accessibility label on the bookmark button in the reader HUD when the current page is not yet bookmarked.",
