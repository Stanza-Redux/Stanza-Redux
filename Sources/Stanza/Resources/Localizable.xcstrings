    "Add an OPDS catalog to start browsing books." : {
      "comment" : "Instructional message shown on the Catalogs screen when no catalogs have been added.",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fügen Sie einen OPDS-Katalog hinzu, um Bücher zu durchsuchen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Añade un catálogo OPDS para empezar a buscar libros."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ajoutez un catalogue OPDS pour commencer à parcourir des livres."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
